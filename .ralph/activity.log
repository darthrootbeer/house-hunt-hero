import sys
sys.path.insert(0, '.')
from datetime import datetime

print('=' * 60)
print('END-TO-END TEST: Maine MLS, Brokerages, Credit Unions')
print(f'Started: {datetime.now().isoformat()}')
print('=' * 60)

# Import the adapters we're testing
from src.ingestion.adapters.maine_listings import MaineListingsAdapter
from src.ingestion.adapters.landing_real_estate import LandingRealEstateAdapter
from src.ingestion.adapters.realty_of_maine import RealtyOfMaineAdapter
from src.normalization.mapper import normalize_many
from src.normalization.schema import Listing

# Run ingestion
adapters = [
    MaineListingsAdapter(),
    LandingRealEstateAdapter(),
    RealtyOfMaineAdapter(),
]

print('\n--- Ingestion Phase ---')
all_raw = []
for adapter in adapters:
    print(f'Fetching from {adapter.source_id}...')
    start = datetime.now()
    try:
        raw = adapter.fetch()
        elapsed = (datetime.now() - start).total_seconds()
        print(f'  ✓ {len(raw)} listings in {elapsed:.1f}s')
        all_raw.extend(raw)
    except Exception as e:
        print(f'  ✗ Error: {e}')

print(f'\nTotal raw listings: {len(all_raw)}')

# Normalize
print('\n--- Normalization Phase ---')
try:
    normalized = normalize_many(all_raw)
    print(f'Normalized {len(normalized)} listings')
    
    # Verify listing structure
    if normalized:
        sample = normalized[0]
        print(f'\nSample normalized listing:')
        print(f'  ID: {sample.listing_id}')
        print(f'  Source: {sample.source}')
        print(f'  URL: {sample.listing_url[:60]}...')
        if sample.address:
            print(f'  Address: {sample.address.raw}')
        print(f'  Price: {sample.price}')
except Exception as e:
    print(f'Normalization error: {e}')
    normalized = []

print('\n' + '=' * 60)
print('TEST SUMMARY')
print('=' * 60)
print(f'Raw listings fetched: {len(all_raw)}')
print(f'Normalized listings: {len(normalized)}')
print(f'Status: {\"PASS\" if len(all_raw) > 0 else \"FAIL\"}')
print('=' * 60)
