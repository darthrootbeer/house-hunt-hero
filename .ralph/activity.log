import sys
sys.path.insert(0, '.')
from datetime import datetime

# Test just the updated adapters
from src.ingestion.adapters.maine_listings import MaineListingsAdapter
from src.ingestion.adapters.landing_real_estate import LandingRealEstateAdapter
from src.ingestion.adapters.realty_of_maine import RealtyOfMaineAdapter

adapters = [
    ('Maine Listings (MLS)', MaineListingsAdapter()),
    ('Landing Real Estate', LandingRealEstateAdapter()),
    ('Realty of Maine', RealtyOfMaineAdapter()),
]

print('=' * 60)
print('TESTING UPDATED ADAPTERS')
print('=' * 60)

results = []
for name, adapter in adapters:
    print(f'\nTesting: {name}')
    start = datetime.now()
    try:
        listings = adapter.fetch()
        elapsed = (datetime.now() - start).total_seconds()
        print(f'  ✓ Found {len(listings)} listings in {elapsed:.1f}s')
        if listings:
            print(f'  Sample: {listings[0].title[:50]}...')
        results.append((name, len(listings), None))
    except Exception as e:
        elapsed = (datetime.now() - start).total_seconds()
        print(f'  ✗ Error: {e}')
        results.append((name, 0, str(e)))

print('\n' + '=' * 60)
print('SUMMARY')
print('=' * 60)
total = sum(r[1] for r in results)
print(f'Total listings found: {total}')
for name, count, err in results:
    status = '✓' if count > 0 else ('✗' if err else '-')
    print(f'  {status} {name}: {count} listings')
" 2>&1 → exit 0
