  "core_filters_for_basic_search_ai": {
    "property_type_include": [
      "single_family",
      "house",
      "cabin",
      "cottage"
    ],
    "property_type_exclude": [
      "condo",
      "townhouse",
      "manufactured",
      "mobile_home",
      "co_op"
    ],
    "hoa_required": false,
    "bedrooms_min": 3,
