      "requirements": [
        "two distinct spaces",
        "each fits a desk and chair",
        "some visual or sound separation"
      ]
    },
    "media_room": {
      "required": true,
      "acceptable_descriptions": [
        "family room",
        "den",
        "media room",
        "bonus room"
      ],
      "requirements": [
        "dedicated room",
        "wall for TV",
        "not a main hallway/traffic path",
        "layout supports seating"
      ]
